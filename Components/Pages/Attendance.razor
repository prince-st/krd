@page "/attendance"
@page "/myattendance"
@inject AuthService Auth
@inject AttendanceService Svc
@inject NavigationManager Nav
@using AttRec = KRD.AttendanceWeb.Models.Attendance
@using KRD.AttendanceWeb.Models

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login", forceLoad: false); return; }

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 style="color:#e0e0ff; font-weight:700; margin:0;">@(Auth.IsAdminLoggedIn ? "Attendance Management" : "My Attendance")</h4>
        <p style="color:#6666aa; font-size:0.83rem; margin:4px 0 0;">@records.Count record(s) found</p>
    </div>
    @if (Auth.IsAdminLoggedIn)
    {
        <button @onclick="() => OpenAdd()" style="padding:9px 18px; background:linear-gradient(135deg,#4361ee,#7209b7); border:none; border-radius:8px; color:white; font-weight:600; cursor:pointer; font-size:0.9rem;">
            <i class="bi bi-plus-lg me-2"></i>Add Record
        </button>
    }
</div>

<!-- Filters -->
<div style="background:#1a1a2e; border-radius:10px; padding:16px 20px; border:1px solid #2a2a4a; margin-bottom:18px;">
    <div class="row g-2 align-items-end">
        <div class="col-auto">
            <label style="@LblStyle">From</label>
            <input type="date" @bind="from" style="@InputStyle width:auto;" />
        </div>
        <div class="col-auto">
            <label style="@LblStyle">To</label>
            <input type="date" @bind="to" style="@InputStyle width:auto;" />
        </div>
        @if (Auth.IsAdminLoggedIn)
        {
            <div class="col-auto">
                <label style="@LblStyle">Employee</label>
                <select @bind="filterEmpId" style="@InputStyle width:auto; min-width:160px;">
                    <option value="0">All Employees</option>
                    @foreach (var e in allEmps)
                    { <option value="@e.Id">@e.FullName</option> }
                </select>
            </div>
            <div class="col-auto">
                <label style="@LblStyle">Status</label>
                <select @bind="filterStatus" style="@InputStyle width:auto;">
                    <option value="">All</option>
                    @foreach (var s in Enum.GetValues<AttendanceStatus>())
                    { <option value="@s">@s</option> }
                </select>
            </div>
        }
        <div class="col-auto" style="padding-bottom:1px;">
            <button @onclick="Load" style="padding:9px 20px; background:#4361ee; border:none; border-radius:8px; color:white; font-weight:600; cursor:pointer;">
                <i class="bi bi-funnel me-1"></i>Filter
            </button>
        </div>
    </div>
</div>

<!-- Table -->
<div style="background:#1a1a2e; border-radius:10px; border:1px solid #2a2a4a; overflow:hidden;">
    <div style="overflow-x:auto;">
        <table class="table table-dark table-hover mb-0" style="font-size:0.85rem;">
            <thead>
                <tr style="color:#6666aa; font-size:0.75rem; text-transform:uppercase; background:#16213e;">
                    @if (Auth.IsAdminLoggedIn) { <th style="padding:12px 16px;">Employee</th> }
                    <th style="padding:12px 16px;">Date</th>
                    <th style="padding:12px 16px;">Check In</th>
                    <th style="padding:12px 16px;">Check Out</th>
                    <th style="padding:12px 16px;">Hours</th>
                    <th style="padding:12px 16px;">Overtime</th>
                    <th style="padding:12px 16px;">Late</th>
                    <th style="padding:12px 16px;">Status</th>
                    @if (Auth.IsAdminLoggedIn) { <th style="padding:12px 16px;">Actions</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Filtered())
                {
                    <tr style="color:#c0c0e0; vertical-align:middle; border-bottom:1px solid #1e2040;">
                        @if (Auth.IsAdminLoggedIn)
                        {
                            <td style="padding:11px 16px; font-weight:600; color:#e0e0ff;">@(a.Employee?.FullName ?? "—")</td>
                        }
                        <td style="padding:11px 16px; color:#8888aa;">@a.Date.ToString("MMM dd, yyyy")</td>
                        <td style="padding:11px 16px; color:#22c55e; font-weight:600;">@(a.CheckInTime?.ToString("hh:mm tt") ?? "—")</td>
                        <td style="padding:11px 16px; color:#4361ee; font-weight:600;">@(a.CheckOutTime?.ToString("hh:mm tt") ?? "—")</td>
                        <td style="padding:11px 16px; color:#818cf8; font-weight:600;">@(a.WorkingHours > 0 ? $"{a.WorkingHours:F1}h" : "—")</td>
                        <td style="padding:11px 16px; color:#f59e0b;">@(a.OvertimeHours > 0 ? $"+{a.OvertimeHours:F1}h" : "—")</td>
                        <td style="padding:11px 16px;">
                            @if (a.IsLate)
                            { <span style="color:#f59e0b; font-size:0.8rem; font-weight:600;"><i class="bi bi-clock me-1"></i>+@(a.LateMinutes)m</span> }
                            else
                            { <span style="color:#4a4a6a; font-size:0.8rem;">—</span> }
                        </td>
                        <td style="padding:11px 16px;"><StatusBadge Status="@a.Status.ToString()"/></td>
                        @if (Auth.IsAdminLoggedIn)
                        {
                            <td style="padding:11px 16px;">
                                <button @onclick="() => OpenEdit(a)"
                                        style="padding:4px 10px; background:rgba(67,97,238,0.15); color:#818cf8; border:1px solid rgba(67,97,238,0.3); border-radius:6px; font-size:0.78rem; cursor:pointer; margin-right:5px;">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button @onclick="() => DeleteRecord(a.Id)"
                                        style="padding:4px 10px; background:rgba(239,68,68,0.12); color:#ef4444; border:1px solid rgba(239,68,68,0.3); border-radius:6px; font-size:0.78rem; cursor:pointer;">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        }
                    </tr>
                }
                @if (!Filtered().Any())
                {
                    <tr><td colspan="9" style="text-align:center; color:#4a4a6a; padding:32px; font-size:0.9rem;">
                        <i class="bi bi-calendar-x" style="font-size:2rem; display:block; margin-bottom:8px; color:#2a2a4a;"></i>
                        No attendance records found
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add / Edit Modal -->
@if (showModal && Auth.IsAdminLoggedIn)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.75);display:flex;align-items:center;justify-content:center;z-index:2000;">
        <div style="background:#1a1a2e; border-radius:14px; padding:32px; width:520px; max-height:90vh; overflow-y:auto; border:1px solid #2a2a4a; box-shadow:0 24px 64px rgba(0,0,0,0.6);">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
                <h5 style="color:#e0e0ff; font-weight:700; margin:0;">@(isEditMode ? "Edit Attendance" : "Add Attendance Record")</h5>
                <button @onclick="CloseModal" style="background:none; border:none; color:#6666aa; font-size:1.3rem; cursor:pointer; padding:0;">×</button>
            </div>

            <div style="margin-bottom:14px;">
                <label style="@LblStyle">Employee *</label>
                <select @bind="form.EmployeeId" style="@InputStyle">
                    <option value="0">— Select Employee —</option>
                    @foreach (var e in allEmps)
                    { <option value="@e.Id">@e.FullName (@e.EmployeeId)</option> }
                </select>
            </div>
            <div style="margin-bottom:14px;">
                <label style="@LblStyle">Date *</label>
                <input type="date" @bind="form.Date" style="@InputStyle" />
            </div>
            <div class="row g-3" style="margin-bottom:14px;">
                <div class="col-6">
                    <label style="@LblStyle">Check In Time</label>
                    <input type="time" value="@checkInStr" @onchange="e => checkInStr = e.Value?.ToString() ?? string.Empty" style="@InputStyle" />
                </div>
                <div class="col-6">
                    <label style="@LblStyle">Check Out Time</label>
                    <input type="time" value="@checkOutStr" @onchange="e => checkOutStr = e.Value?.ToString() ?? string.Empty" style="@InputStyle" />
                </div>
            </div>
            <div style="margin-bottom:14px;">
                <label style="@LblStyle">Status *</label>
                <select @bind="form.Status" style="@InputStyle">
                    @foreach (var s in Enum.GetValues<AttendanceStatus>())
                    { <option value="@s">@s</option> }
                </select>
            </div>
            <div style="margin-bottom:14px;">
                <label style="@LblStyle">Notes</label>
                <input @bind="form.Notes" placeholder="Optional notes..." style="@InputStyle" />
            </div>
            <div class="row g-3" style="margin-bottom:14px;">
                <div class="col-6">
                    <label style="@LblStyle">Late? <input type="checkbox" @bind="form.IsLate" class="ms-2" /></label>
                    @if (form.IsLate)
                    {
                        <input @bind="form.LateMinutes" type="number" min="0" placeholder="Minutes late" style="@InputStyle margin-top:6px;" />
                    }
                </div>
                <div class="col-6">
                    <label style="@LblStyle">Early Exit? <input type="checkbox" @bind="form.IsEarlyExit" class="ms-2" /></label>
                    @if (form.IsEarlyExit)
                    {
                        <input @bind="form.EarlyExitMinutes" type="number" min="0" placeholder="Minutes early" style="@InputStyle margin-top:6px;" />
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(modalError))
            {
                <div style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); border-radius:8px; padding:10px 14px; margin-bottom:14px; color:#ef4444; font-size:0.85rem;">
                    <i class="bi bi-exclamation-triangle me-2"></i>@modalError
                </div>
            }

            <div class="d-flex gap-3 mt-2">
                <button @onclick="SaveRecord" style="flex:1; padding:12px; background:linear-gradient(135deg,#4361ee,#7209b7); border:none; border-radius:8px; color:white; font-weight:700; cursor:pointer;">
                    <i class="bi bi-check-lg me-2"></i>@(isEditMode ? "Update" : "Add Record")
                </button>
                <button @onclick="CloseModal" style="flex:1; padding:12px; background:#2a2a4a; border:none; border-radius:8px; color:#8888aa; cursor:pointer;">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private DateTime from = DateTime.Today.AddDays(-30);
    private DateTime to   = DateTime.Today;
    private int filterEmpId = 0;
    private string filterStatus = "";
    private List<AttRec> records = new();
    private List<KRD.AttendanceWeb.Models.Employee> allEmps = new();

    // Modal state
    private bool showModal, isEditMode;
    private AttRec form = new();
    private string checkInStr = "", checkOutStr = "", modalError = "";

    private string InputStyle => "width:100%; padding:9px 12px; background:#0f0f1a; border:1px solid #2a2a4a; border-radius:8px; color:#e0e0ff; font-size:0.88rem; box-sizing:border-box;";
    private string LblStyle   => "color:#8888aa; font-size:0.78rem; font-weight:600; display:block; margin-bottom:5px;";

    protected override void OnInitialized()
    {
        if (Auth.IsAdminLoggedIn) allEmps = Svc.GetAllEmployees(false);
        Load();
    }

    private void Load()
    {
        if (Auth.IsAdminLoggedIn)
            records = filterEmpId == 0
                ? Svc.GetAttendanceRange(from, to)
                : Svc.GetAttendanceByEmployee(filterEmpId, from, to)
                     .Select(a => { a.Employee = allEmps.FirstOrDefault(e => e.Id == a.EmployeeId); return a; })
                     .ToList();
        else
            records = Svc.GetAttendanceByEmployee(Auth.CurrentEmployee!.Id, from, to);
    }

    private IEnumerable<AttRec> Filtered() =>
        string.IsNullOrEmpty(filterStatus) ? records
        : records.Where(r => r.Status.ToString() == filterStatus);

    private void OpenAdd()
    {
        form = new AttRec { Date = DateTime.Today, Status = AttendanceStatus.Present };
        checkInStr = "09:00"; checkOutStr = "18:00";
        isEditMode = false; modalError = ""; showModal = true;
    }

    private void OpenEdit(AttRec a)
    {
        form = new AttRec
        {
            Id = a.Id, EmployeeId = a.EmployeeId, Date = a.Date,
            Status = a.Status, Notes = a.Notes,
            IsLate = a.IsLate, LateMinutes = a.LateMinutes,
            IsEarlyExit = a.IsEarlyExit, EarlyExitMinutes = a.EarlyExitMinutes,
            WorkingHours = a.WorkingHours, OvertimeHours = a.OvertimeHours,
            ShortHours = a.ShortHours, RequiredHours = a.RequiredHours
        };
        checkInStr  = a.CheckInTime?.ToString("HH:mm")  ?? "";
        checkOutStr = a.CheckOutTime?.ToString("HH:mm") ?? "";
        isEditMode = true; modalError = ""; showModal = true;
    }

    private void CloseModal() { showModal = false; modalError = ""; }

    private void SaveRecord()
    {
        modalError = "";
        if (form.EmployeeId == 0) { modalError = "Please select an employee."; return; }

        // Parse times
        DateTime? cin  = null, cout = null;
        if (!string.IsNullOrEmpty(checkInStr) && TimeSpan.TryParse(checkInStr, out var ts1))
            cin = form.Date.Date + ts1;
        if (!string.IsNullOrEmpty(checkOutStr) && TimeSpan.TryParse(checkOutStr, out var ts2))
            cout = form.Date.Date + ts2;
        if (cin != null && cout != null && cout <= cin)
        { modalError = "Check out must be after check in."; return; }

        form.CheckInTime  = cin;
        form.CheckOutTime = cout;
        if (cin != null && cout != null)
        {
            form.WorkingHours  = (cout.Value - cin.Value).TotalHours;
            var settings = Svc.GetSettings();
            form.OvertimeHours = Math.Max(0, form.WorkingHours - settings.RequiredWorkingHours);
            form.ShortHours    = Math.Max(0, settings.RequiredWorkingHours - form.WorkingHours);
            form.RequiredHours = settings.RequiredWorkingHours;
        }

        if (isEditMode) Svc.UpdateAttendance(form);
        else            Svc.AddAttendance(form);

        showModal = false;
        Load();
    }

    private void DeleteRecord(int id) { Svc.DeleteAttendance(id); Load(); }
}
