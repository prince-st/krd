@page "/login"
@layout KRD.AttendanceWeb.Components.Layout.EmptyLayout
@inject AuthService Auth
@inject NavigationManager Nav


<div style="min-height:100vh; display:flex; background:#0f0f1a;">
    <!-- Left panel -->
    <div style="width:420px; background:linear-gradient(160deg,#4361ee,#7209b7); display:flex; flex-direction:column; justify-content:center; align-items:center; padding:40px; flex-shrink:0;">
        <div style="width:90px;height:90px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:900;color:white;border:2px solid rgba(255,255,255,0.3);margin-bottom:24px;">KRD</div>
        <h2 style="color:white;font-weight:800;font-size:1.7rem;margin-bottom:8px;text-align:center;">KRD Attendance</h2>
        <p style="color:rgba(255,255,255,0.7);text-align:center;font-size:0.95rem;margin-bottom:40px;">Employee Attendance Management System</p>
        <div style="width:100%;">
            @foreach (var f in new[] { "Real-time Attendance Tracking", "Leave Management", "Detailed Reports", "Holiday Management" })
            {
                <div style="display:flex;align-items:center;margin-bottom:14px;color:rgba(255,255,255,0.85);font-size:0.9rem;">
                    <i class="bi bi-check-circle-fill me-3" style="color:#4cc9f0;font-size:1rem;"></i>@f
                </div>
            }
        </div>
        <div style="margin-top:auto;color:rgba(255,255,255,0.4);font-size:0.75rem;">v1.0 © 2024 KRD</div>
    </div>

    <!-- Right panel -->
    <div style="flex:1; display:flex; align-items:center; justify-content:center; padding:40px;">
        <div style="width:100%;max-width:420px; background:#1a1a2e; border-radius:12px; padding:40px; border:1px solid #2a2a4a; box-shadow:0 20px 60px rgba(0,0,0,0.5);">
            <div style="height:4px; background:linear-gradient(90deg,#4361ee,#7209b7); border-radius:4px 4px 0 0; margin:-40px -40px 32px -40px;"></div>

            <h3 style="color:#e0e0ff; font-weight:700; margin-bottom:4px;">Welcome Back</h3>
            <p style="color:#6666aa; font-size:0.88rem; margin-bottom:28px;">Sign in to continue to KRD Attendance</p>

            <!-- Toggle -->
            <div style="display:flex; background:#0f0f1a; border-radius:8px; padding:4px; margin-bottom:24px;">
                <button style="flex:1; padding:10px; border:none; border-radius:6px; font-weight:600; font-size:0.88rem; cursor:pointer;
                    background:@(isAdmin ? "#4361ee" : "transparent"); color:@(isAdmin ? "white" : "#6666aa");"
                    @onclick="() => { isAdmin=true; error=null; }">Admin</button>
                <button style="flex:1; padding:10px; border:none; border-radius:6px; font-weight:600; font-size:0.88rem; cursor:pointer;
                    background:@(!isAdmin ? "#4361ee" : "transparent"); color:@(!isAdmin ? "white" : "#6666aa");"
                    @onclick="() => { isAdmin=false; error=null; }">Employee</button>
            </div>

            <!-- Fields -->
            <div style="margin-bottom:16px;">
                <label style="color:#8888aa; font-size:0.8rem; font-weight:600; display:block; margin-bottom:6px;">
                    @(isAdmin ? "Email Address" : "Employee ID")
                </label>
                <input @bind="identifier" @bind:event="oninput"
                       placeholder="@(isAdmin ? "admin@krd.com" : "Enter your employee ID")"
                       style="width:100%; padding:12px 14px; background:#0f0f1a; border:1px solid #2a2a4a; border-radius:8px; color:#e0e0ff; font-size:0.95rem; outline:none; box-sizing:border-box;"
                       @onkeydown="HandleKey" />
            </div>
            <div style="margin-bottom:10px;">
                <label style="color:#8888aa; font-size:0.8rem; font-weight:600; display:block; margin-bottom:6px;">Password</label>
                <input @bind="password" @bind:event="oninput" type="password"
                       placeholder="Enter your password"
                       style="width:100%; padding:12px 14px; background:#0f0f1a; border:1px solid #2a2a4a; border-radius:8px; color:#e0e0ff; font-size:0.95rem; outline:none; box-sizing:border-box;"
                       @onkeydown="HandleKey" />
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div style="color:#ef4444; font-size:0.82rem; margin-bottom:12px; padding:8px 12px; background:rgba(239,68,68,0.1); border-radius:6px;">
                    <i class="bi bi-exclamation-triangle me-2"></i>@error
                </div>
            }

            <button @onclick="DoLogin" disabled="@loading"
                    style="width:100%; padding:13px; background:linear-gradient(135deg,#4361ee,#7209b7); border:none; border-radius:8px; color:white; font-weight:700; font-size:1rem; cursor:pointer; margin-top:4px;">
                @(loading ? "Signing in..." : "Sign In →")
            </button>

            <div style="text-align:center; margin-top:20px; color:#3a3a6a; font-size:0.75rem; padding:8px; background:#0f0f1a; border-radius:6px;">
                Default: admin@krd.com / Admin123
            </div>
        </div>
    </div>
</div>

@code {
    private bool   isAdmin    = true;
    private string identifier = "";
    private string password   = "";
    private string? error;
    private bool   loading;

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Nav.NavigateTo("/dashboard", forceLoad: false);
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoLogin();
    }

    private async Task DoLogin()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(identifier) || string.IsNullOrWhiteSpace(password))
        { error = "Please fill in all fields."; return; }

        loading = true;
        await Task.Delay(50);

        bool ok = isAdmin
            ? Auth.LoginAdmin(identifier.Trim(), password)
            : Auth.LoginEmployee(identifier.Trim(), password);

        loading = false;
        if (ok)
            Nav.NavigateTo("/dashboard", forceLoad: false);
        else
            error = isAdmin ? "Invalid email or password." : "Invalid Employee ID or password.";
    }
}
