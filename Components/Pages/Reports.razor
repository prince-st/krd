@page "/reports"
@inject AuthService Auth
@inject AttendanceService Svc
@inject NavigationManager Nav
@using KRD.AttendanceWeb.Models
@using AttRec = KRD.AttendanceWeb.Models.Attendance

@if (!Auth.IsAdminLoggedIn) { Nav.NavigateTo("/login", forceLoad: false); return; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="color:#e0e0ff; font-weight:700; margin:0;">Attendance Reports</h4>
        <p style="color:#6666aa; font-size:0.85rem; margin:4px 0 0;">Overview and detailed attendance analytics</p>
    </div>
    <a href="/api/export/attendance?from=@from.ToString("yyyy-MM-dd")&to=@to.ToString("yyyy-MM-dd")&empId=@filterEmpId"
       target="_blank"
       style="padding:10px 20px; background:linear-gradient(135deg,#22c55e,#16a34a); border-radius:8px; color:white; font-weight:700; font-size:0.88rem; text-decoration:none; display:flex; align-items:center; gap:8px;">
        <i class="bi bi-file-earmark-excel-fill" style="font-size:1.1rem;"></i> Download Excel
    </a>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3"><StatCard Title="Total Employees"  Value="@totalEmp.ToString()"     Icon="bi-people"          Color="#4361ee"/></div>
    <div class="col-md-3"><StatCard Title="Present Today"   Value="@presentToday.ToString()"  Icon="bi-person-check"    Color="#22c55e"/></div>
    <div class="col-md-3"><StatCard Title="Late Today"      Value="@lateToday.ToString()"     Icon="bi-clock-history"   Color="#f59e0b"/></div>
    <div class="col-md-3"><StatCard Title="Pending Leaves"  Value="@pendingLeaves.ToString()" Icon="bi-calendar-x"      Color="#ef4444"/></div>
</div>

<!-- Filter Bar -->
<div style="background:#1a1a2e; border-radius:10px; padding:18px 24px; border:1px solid #2a2a4a; margin-bottom:20px;">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label style="color:#8888aa; font-size:0.78rem; font-weight:600; display:block; margin-bottom:5px;">FROM</label>
            <input type="date" @bind="from" style="@InputStyle" />
        </div>
        <div class="col-md-3">
            <label style="color:#8888aa; font-size:0.78rem; font-weight:600; display:block; margin-bottom:5px;">TO</label>
            <input type="date" @bind="to" style="@InputStyle" />
        </div>
        <div class="col-md-3">
            <label style="color:#8888aa; font-size:0.78rem; font-weight:600; display:block; margin-bottom:5px;">EMPLOYEE</label>
            <select @bind="filterEmpId" style="@InputStyle">
                <option value="0">All Employees</option>
                @foreach (var e in employees)
                {
                    <option value="@e.Id">@e.FullName</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button @onclick="Load" style="width:100%; padding:10px; background:#4361ee; border:none; border-radius:8px; color:white; font-weight:600; cursor:pointer;">
                <i class="bi bi-funnel me-2"></i>Generate Report
            </button>
        </div>
    </div>
</div>

<!-- Monthly Summary per Employee -->
@if (summary.Any())
{
    <div style="background:#1a1a2e; border-radius:10px; padding:20px; border:1px solid #2a2a4a; margin-bottom:20px;">
        <h6 style="color:#e0e0ff; font-weight:600; margin-bottom:16px;">
            <i class="bi bi-bar-chart me-2" style="color:#4361ee;"></i>Summary — @from.ToString("MMM dd") to @to.ToString("MMM dd, yyyy")
        </h6>
        <div style="overflow-x:auto;">
            <table class="table table-dark table-hover mb-0" style="font-size:0.85rem;">
                <thead>
                    <tr style="color:#6666aa; font-size:0.75rem; text-transform:uppercase;">
                        <th>Employee</th>
                        <th>Dept</th>
                        <th style="color:#22c55e;">Present</th>
                        <th style="color:#f59e0b;">Late</th>
                        <th style="color:#06b6d4;">Early Exit</th>
                        <th style="color:#ef4444;">Absent</th>
                        <th style="color:#818cf8;">Total Hours</th>
                        <th style="color:#f59e0b;">Overtime</th>
                        <th>Attendance%</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in summary)
                    {
                        var pct = row.WorkingDays > 0 ? (double)row.Present / row.WorkingDays * 100 : 0;
                        <tr style="color:#c0c0e0; vertical-align:middle;">
                            <td style="font-weight:600; color:#e0e0ff;">@row.Name</td>
                            <td style="color:#8888aa; font-size:0.8rem;">@row.Dept</td>
                            <td><span style="color:#22c55e; font-weight:600;">@row.Present</span></td>
                            <td><span style="color:#f59e0b; font-weight:600;">@row.Late</span></td>
                            <td><span style="color:#06b6d4; font-weight:600;">@row.EarlyExit</span></td>
                            <td><span style="color:#ef4444; font-weight:600;">@row.Absent</span></td>
                            <td><span style="color:#818cf8; font-weight:600;">@($"{row.TotalHours:F1}h")</span></td>
                            <td><span style="color:#f59e0b;">@($"{row.Overtime:F1}h")</span></td>
                            <td>
                                <div style="display:flex; align-items:center; gap:8px;">
                                    <div style="flex:1; background:#2a2a4a; border-radius:10px; height:6px; min-width:60px;">
                                        <div style="height:6px; border-radius:10px; width:@($"{Math.Min(pct,100):F0}%"); background:@(pct>=80?"#22c55e":pct>=60?"#f59e0b":"#ef4444");"></div>
                                    </div>
                                    <span style="font-size:0.8rem; color:@(pct>=80?"#22c55e":pct>=60?"#f59e0b":"#ef4444"); font-weight:600; min-width:36px;">@($"{pct:F0}%")</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Detailed Records -->
<div style="background:#1a1a2e; border-radius:10px; padding:20px; border:1px solid #2a2a4a;">
    <h6 style="color:#e0e0ff; font-weight:600; margin-bottom:16px;">
        <i class="bi bi-list-ul me-2" style="color:#4361ee;"></i>Detailed Records
        <span style="color:#6666aa; font-weight:400; font-size:0.8rem; margin-left:8px;">(@records.Count entries)</span>
    </h6>
    <div style="overflow-x:auto;">
        <table class="table table-dark table-hover mb-0" style="font-size:0.83rem;">
            <thead>
                <tr style="color:#6666aa; font-size:0.75rem; text-transform:uppercase;">
                    <th>Employee</th><th>Date</th><th>Check In</th><th>Check Out</th>
                    <th>Hours</th><th>Overtime</th><th>Late?</th><th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in records)
                {
                    <tr style="color:#c0c0e0; vertical-align:middle;">
                        <td style="font-weight:500;">@(a.Employee?.FullName ?? "-")</td>
                        <td style="color:#8888aa;">@a.Date.ToString("MMM dd, yyyy")</td>
                        <td style="color:#22c55e;">@(a.CheckInTime?.ToString("hh:mm tt") ?? "-")</td>
                        <td style="color:#4361ee;">@(a.CheckOutTime?.ToString("hh:mm tt") ?? "-")</td>
                        <td style="color:#818cf8; font-weight:600;">@(a.WorkingHours > 0 ? $"{a.WorkingHours:F1}h" : "-")</td>
                        <td style="color:#f59e0b;">@(a.OvertimeHours > 0 ? $"+{a.OvertimeHours:F1}h" : "-")</td>
                        <td>@(a.IsLate ? $"<span style='color:#f59e0b;'>Yes (+{a.LateMinutes}m)</span>" : "<span style='color:#6666aa;'>No</span>")</td>
                        <td><StatusBadge Status="@a.Status.ToString()"/></td>
                    </tr>
                }
                @if (!records.Any())
                {
                    <tr><td colspan="8" style="text-align:center; color:#4a4a6a; padding:24px;">No records for selected range. Click "Generate Report" to load data.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private DateTime from = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime to   = DateTime.Today;
    private int filterEmpId = 0;
    private List<Employee> employees = new();
    private List<AttRec> records = new();
    private List<EmpSummary> summary = new();
    private int totalEmp, presentToday, lateToday, pendingLeaves;
    private string InputStyle => "width:100%; padding:9px 12px; background:#0f0f1a; border:1px solid #2a2a4a; border-radius:8px; color:#e0e0ff; font-size:0.88rem; box-sizing:border-box;";

    protected override void OnInitialized()
    {
        employees    = Svc.GetAllEmployees(false);
        totalEmp     = Svc.TotalActive();
        presentToday = Svc.PresentToday();
        lateToday    = Svc.LateToday();
        pendingLeaves= Svc.PendingLeaves();
        Load();
    }

    private void Load()
    {
        records = filterEmpId == 0
            ? Svc.GetAttendanceRange(from, to)
            : Svc.GetAttendanceByEmployee(filterEmpId, from, to)
                 .Select(a => { a.Employee = employees.FirstOrDefault(e => e.Id == a.EmployeeId); return a; })
                 .ToList();

        var empList = filterEmpId == 0 ? employees : employees.Where(e => e.Id == filterEmpId).ToList();
        int workDays = WorkingDays(from, to);

        summary = empList.Select(emp =>
        {
            var recs = records.Where(r => r.EmployeeId == emp.Id).ToList();
            return new EmpSummary
            {
                Name       = emp.FullName,
                Dept       = emp.Department?.Name ?? "-",
                Present    = recs.Count(r => r.Status == AttendanceStatus.Present || r.Status == AttendanceStatus.Late),
                Late       = recs.Count(r => r.IsLate),
                EarlyExit  = recs.Count(r => r.IsEarlyExit),
                Absent     = Math.Max(0, workDays - recs.Count(r => r.CheckInTime != null)),
                TotalHours = recs.Sum(r => r.WorkingHours),
                Overtime   = recs.Sum(r => r.OvertimeHours),
                WorkingDays= workDays
            };
        }).ToList();
    }

    private int WorkingDays(DateTime start, DateTime end)
    {
        int count = 0;
        for (var d = start; d <= end; d = d.AddDays(1))
            if (d.DayOfWeek != DayOfWeek.Saturday && d.DayOfWeek != DayOfWeek.Sunday)
                count++;
        return count;
    }

    private class EmpSummary
    {
        public string Name = ""; public string Dept = "";
        public int Present, Late, EarlyExit, Absent, WorkingDays;
        public double TotalHours, Overtime;
    }
}
